# environments/prod/terraform.tfvars.example
# 이 파일을 terraform.tfvars로 복사하고 값을 설정하세요

# Database
db_password = "your-secure-password-here"

# Admin access (NAT Instance SSH)
admin_cidr_blocks = ["your-ip/32"]

# API Keys (optional)
openai_api_key     = ""
openrouter_api_key = ""
jwt_secret         = "your-jwt-secret-here"

# Redis (기본값 사용 시 생략 가능)
# redis_node_type          = "cache.r6g.large"
# redis_num_shards         = 3
# redis_replicas_per_shard = 1
